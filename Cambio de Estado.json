      "id": "e81f6214-92fd-4261-b6b2-2ce8293bc195",
      "name": "Schedule Trigger"
    },
    {
      "parameters": {
        "jsCode": "const tickets = $input.all();\nconst ahora = new Date();\nconst CINCO_MINUTOS = 5 * 60 * 1000;\n\nconst cambios = [];\n\nfor (const item of tickets) {\n  const t = item.json;\n  if (!t.id_ticket || !t.fecha_creacion) continue;\n  if (t.estado === 'Cerrado') continue;\n\n  const fechaStr = t.fecha_creacion.trim().replace(' ', 'T');\n  const fechaCreacion = new Date(fechaStr.length === 18 ? fechaStr.replace('T', 'T0') + 'Z' : fechaStr + 'Z');\n  const diff = ahora - fechaCreacion;\n\n  if (t.estado === 'Abierto' && diff >= CINCO_MINUTOS) {\n    cambios.push({ json: { id_ticket: t.id_ticket, estado_actual: 'Abierto', nuevo_estado: 'En proceso', creado_por: t.creado_por } });\n  }\n\n  if (t.estado === 'En proceso' && diff >= CINCO_MINUTOS * 2) {\n    cambios.push({ json: { id_ticket: t.id_ticket, estado_actual: 'En proceso', nuevo_estado: 'Cerrado', creado_por: t.creado_por } });\n  }\n}\n\nif (cambios.length === 0) {\n  return [{ json: { sin_cambios: true } }];\n}\n\nreturn cambios;"
      },
