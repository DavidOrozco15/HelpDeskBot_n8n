    {
      "parameters": {
        "jsCode": "const resultado = $input.all();\nconst origen = $('Logica').first().json;\n\nconst MENU = `\\n\\n*Escribe 9 para volver al inicio.*`;\n\nlet mensaje;\n\nif (resultado.length === 0 || !resultado[0].json.id_ticket) {\n  mensaje = `❌ *Ticket no encontrado*\\n\\nNo existe ningún ticket con el ID: \\`${origen.consulta_id}\\`\\n\\nVerifica que el ID sea correcto.${MENU}`;\n} else {\n  const t = resultado[0].json;\n  const estadoEmoji = t.estado === 'Abierto' ? '🟡' : t.estado === 'En proceso' ? '🔵' : '✅';\n  mensaje = `🎫 *Ticket: \\`${t.id_ticket}\\`*\\n\\n🖥️ *Tipo:* ${t.tipo}\\n⚡ *Prioridad:* ${t.prioridad}\\n${estadoEmoji} *Estado:* ${t.estado}\\n📅 *Fecha:* ${t.fecha_creacion}\\n👤 *Creado por:* ${t.creado_por}\\n\\n📄 *Descripción:*\\n_${t.descripcion}_${MENU}`;\n}\n\nreturn [{\n  json: {\n    ...origen,\n    mensaje\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -304,
