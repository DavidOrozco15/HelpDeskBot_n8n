    {
      "parameters": {
        "jsCode": "const tickets = $input.all();\nconst origen = $('Logica').first().json;\n\nconst MENU = `\\n\\n*Escribe 9 para volver al inicio.*`; \n\nconst filtrados = tickets.filter(t => t.json.id_ticket);\n\nif (filtrados.length === 0) {\n  return [{ json: { ...origen, mensaje: `📊 *Reporte General*\\n\\nNo hay solicitudes registradas aún.${MENU}` } }];\n}\n\nconst total      = filtrados.length;\nconst abiertos   = filtrados.filter(t => t.json.estado === 'Abierto').length;\nconst enProceso  = filtrados.filter(t => t.json.estado === 'En proceso').length;\nconst cerrados   = filtrados.filter(t => t.json.estado === 'Cerrado').length;\n\nconst porTipo = {};\nfiltrados.forEach(t => {\n  const tipo = t.json.tipo || 'Desconocido';\n  porTipo[tipo] = (porTipo[tipo] || 0) + 1;\n});\n\nconst porPrioridad = { Alta: 0, Media: 0, Baja: 0 };\nfiltrados.forEach(t => {\n  const p = t.json.prioridad;\n  if (porPrioridad[p] !== undefined) porPrioridad[p]++;\n});\n\nconst tipoLines = Object.entries(porTipo).map(([k,v]) => `  • ${k}: ${v}`).join('\\n');\n\nconst mensaje = `📊 *Reporte General de Solicitudes*\\n\\n━━━━━━━━━━━━━━━\\n🗂️ *Total de tickets:* *${total}*\\n━━━━━━━━━━━━━━━\\n\\n📈 *Por Estado*\\n🟡 Abiertos: *${abiertos}*\\n🔵 En proceso: *${enProceso}*\\n✅ Cerrados: *${cerrados}*\\n\\n📋 *Por Tipo*\\n${tipoLines}\\n\\n⚡ *Por Prioridad*\\n🔴 Alta: *${porPrioridad.Alta}*\\n🟠 Media: *${porPrioridad.Media}*\\n🟢 Baja: *${porPrioridad.Baja}*${MENU}`;\n\nreturn [{ json: { ...origen, mensaje } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -304,
        368
      ],
