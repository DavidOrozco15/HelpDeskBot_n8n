    {
      "parameters": {
        "jsCode": "const tickets = $input.all();\nconst origen = $('Logica').first().json;\n\nconst MENU = `\\n\\n*Escribe 9 para volver al inicio.*`;\n\nlet mensaje;\n\nif (tickets.length === 0 || !tickets[0].json.id_ticket) {\n  mensaje = `📭 *Sin solicitudes*\\n\\nAún no tienes ninguna solicitud registrada.\\n\\n🆕 Escribe *1* para crear tu primera solicitud.${MENU}`;\n} else {\n  const lines = tickets.map(t => {\n    const ticket = t.json;\n    return `🎫 *${ticket.id_ticket}*\\n    📌 ${ticket.tipo}`;\n  });\n  mensaje = `📂 *Mis Solicitudes*\\n_${tickets.length} encontradas_\\n\\n${lines.join('\\n\\n')}${MENU}`;\n}\n\nreturn [{\n  json: {\n    ...origen,\n    mensaje\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
