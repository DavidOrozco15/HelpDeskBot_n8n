    {
      "parameters": {
        "jsCode": "// ─── 1. Recoger datos ───\nconst vars      = $('Edit Fields').first().json;\nconst chatId    = vars.chatId;\nconst username  = vars.username;\nconst firstName = vars.firstName;\nconst text      = vars.text.toLowerCase().trim();\nconst timestamp = vars.timestamp;\n\n// ─── 2. Parsear sesión ───\nconst sesionItems = $('Leer Sesion').all();\nlet estado       = 'MENU';\nlet datosTmp     = {};\nlet sesionExiste = false;\n\nif (sesionItems.length > 0 && sesionItems[0].json.telegram_user) {\n  estado       = sesionItems[0].json.estado || 'MENU';\n  sesionExiste = true;\n  try {\n    datosTmp = JSON.parse(sesionItems[0].json.datos_temp || '{}');\n  } catch(e) { datosTmp = {}; }\n}\n\n// ─── 3. Validar usuario ───\nconst userItems = $('Leer Usuario').all();\nlet usuarioActivo = false;\nlet nombreUsuario = firstName;\n\nif (userItems.length > 0 && userItems[0].json.telegram_user) {\n  const u = userItems[0].json;\n  usuarioActivo = (u.activo === true || u.activo === 'TRUE' || u.activo === 'true');\n  nombreUsuario = u.nombre || firstName;\n}\n\nif (!usuarioActivo) {\n  return [{\n    json: {\n      chatId, username,\n      mensaje: `⛔ Lo siento, tu usuario no está registrado o no está activo.\\n\\nContacta al administrador.`,\n      nuevo_estado: 'MENU',\n      nuevo_datos_temp: '{}',\n      accion: 'solo_responder',\n      sesionExiste,\n      log_pantalla: estado,\n      log_opcion: text,\n      log_resultado: 'usuario_inactivo'\n    }\n  }];\n}\n\n// ─── 4. Textos ───\nconst MENU_PRINCIPAL = `🤖 *HelpDeskBot*\\n\\n_Por favor, escribe el número de la opción que deseas usar:_\\n\\n🆘 *0* · Ayuda\\n🆕 *1* · Crear solicitud\\n🔎 *2* · Consultar ticket\\n📁 *3* · Mis solicitudes\\n📈 *4* · Reportes\\n🔧 *5* · Configuración`;\nconst MENU_CREAR = `📝 *Nueva Solicitud*\\n\\n_Selecciona el tipo de solicitud:_\\n\\n🖥️ *1* · Soporte técnico \\n_problemas con equipos o sistemas_\\n\\n📋 *2* · Solicitud administrativa \\n_trámites y gestiones internas_\\n\\n💬 *3* · Consulta general \\n_dudas o preguntas diversas_\\n\\n❌ *9* · Cancelar`;\nconst MENU_PRIORIDAD = `⚡ *Prioridad*\\n\\n_Indica el nivel de urgencia de tu solicitud:_\\n\\n🔴 *1* · Alta  \\n_requiere atención inmediata_\\n\\n🟠 *2* · Media \\n_puede atenderse en el corto plazo_\\n\\n🟢 *3* · Baja \\n_sin urgencia, puede esperar_\\n\\n❌ *9* · Cancelar`;\nconst AYUDA = `ℹ️ *Ayuda — HelpDeskBot*\\n\\n🤖 _Soy un bot de soporte interno. Puedo ayudarte a gestionar tus solicitudes de forma rápida y ordenada._\\n\\n*¿Qué puedo hacer?*\\n\\n🆕 *Crear* tickets de soporte técnico, administrativo o consultas\\n🔎 *Consultar* el estado de cualquier ticket por su ID\\n📁 *Ver* todas tus solicitudes registradas\\n📈 *Reportes* con estadísticas generales\\n\\n*¿Cómo navegar?*\\n\\n📌 Escribe el _número_ de la opción que deseas usar\\n❌ Escribe _9_ en cualquier momento para cancelar\\n🏠 Escribe _9_ en algunos menus para volver al inicio\\n\\n⚙️ _Los estados se actualizan automáticamente: Abierto → En proceso → Cerrado_`;\nconst VOLVER = `\\n\\n*Escribe 9 para volver al inicio.*`;\n\nconst TIPOS = { '1': 'Soporte técnico', '2': 'Solicitud administrativa', '3': 'Consulta general' };\nconst PRIORIDADES = { '1': 'Alta', '2': 'Media', '3': 'Baja' };\n\nfunction generarTicketId() {\n  const fecha = new Date().toISOString().slice(0,10).replace(/-/g,'');\n  const rand  = Math.floor(Math.random() * 9000) + 1000;\n  return `TKT-${fecha}-${rand}`;\n}\n\nlet mensaje          = '';\nlet nuevo_estado     = 'MENU';\nlet nuevo_datos_temp = {};\nlet accion           = 'solo_responder';\nlet ticket_data      = null;\nlet consulta_id      = null;\nlet log_resultado    = 'ok';\n\n// ─── Estados ───\nif (estado === 'MENU') {\n  switch(text) {\n    case '0': mensaje = AYUDA; break;\n    case '1': mensaje = MENU_CREAR; nuevo_estado = 'CREAR_TIPO'; break;\n    case '2':\n      mensaje = `🔎 *Consultar Ticket*\\n\\nEscribe el ID del ticket que deseas consultar.\\n\\n📌 _Ejemplo: TKT-20240115-1234_\\n\\n❌ *9* · Cancelar`;\n      nuevo_estado = 'CONSULTAR_ID'; break;\n    case '3': accion = 'mis_solicitudes'; break;\n    case '4': accion = 'reportes'; break;\n    case '5': mensaje = `⚙️ *Configuración*\\n\\nNo hay opciones disponibles.${VOLVER}`; break;\n    case '9':\n    case 'menú':\n    case 'menu':\n      mensaje = MENU_PRINCIPAL; break;\n    default:\n      mensaje = !sesionExiste\n        ? `Hola, soy HelpDeskBot 👋\\n\\nEstoy aquí para ayudarte con solicitudes de soporte.\\n\\n${MENU_PRINCIPAL}`\n        : `⚠️ Opción no reconocida.${VOLVER}`;\n      log_resultado = 'opcion_invalida';\n  }\n}\nelse if (estado === 'CREAR_TIPO') {\n  if (text === '9') { mensaje = `❌ Cancelado.${VOLVER}`; log_resultado = 'cancelado'; }\n  else if (['1','2','3'].includes(text)) { nuevo_datos_temp = { tipo: TIPOS[text] }; mensaje = MENU_PRIORIDAD; nuevo_estado = 'CREAR_PRIORIDAD'; }\n  else { mensaje = `⚠️ Opción inválida.\\n\\n${MENU_CREAR}`; nuevo_estado = 'CREAR_TIPO'; log_resultado = 'opcion_invalida'; }\n}\nelse if (estado === 'CREAR_PRIORIDAD') {\n  if (text === '9') { mensaje = `❌ Cancelado.${VOLVER}`; nuevo_datos_temp = {}; log_resultado = 'cancelado'; }\n  else if (['1','2','3'].includes(text)) { nuevo_datos_temp = { ...datosTmp, prioridad: PRIORIDADES[text] }; mensaje = `📝 *Descripción*\\n\\nEscribe una descripción clara de tu solicitud.\\n\\n📌 _Mínimo 10 caracteres_\\n\\n❌ *9* · Cancelar`; nuevo_estado = 'CREAR_DESCRIPCION'; }\n  else { mensaje = `⚠️ Opción inválida.\\n\\n${MENU_PRIORIDAD}`; nuevo_estado = 'CREAR_PRIORIDAD'; log_resultado = 'opcion_invalida'; }\n}\nelse if (estado === 'CREAR_DESCRIPCION') {\n  if (text === '9') { mensaje = `❌ Cancelado.${VOLVER}`; nuevo_datos_temp = {}; log_resultado = 'cancelado'; }\n  else if (text.length < 10) { mensaje = `⚠️ *Descripción muy corta*\\n\\nPor favor escribe al menos *10 caracteres*.\\n\\n📝 Intenta ser específico sobre el problema.`; nuevo_estado = 'CREAR_DESCRIPCION'; log_resultado = 'descripcion_corta'; }\n  else {\n    const desc = $('Edit Fields').first().json.text.trim();\n    nuevo_datos_temp = { ...datosTmp, descripcion: desc };\n    const fechaPreview = new Date().toISOString().slice(0,19).replace('T',' ');\n    mensaje = `📋 *Resumen de tu solicitud*\\n\\n🖥️ *Tipo:* ${datosTmp.tipo}\\n⚡ *Prioridad:* ${datosTmp.prioridad}\\n📄 *Descripción:* ${desc}\\n📅 *Fecha:* ${fechaPreview}\\n\\n¿Confirmas que deseas guardar esta solicitud?\\n\\n✅ *S* · Confirmar\\n❌ *N* · Cancelar`;\n    nuevo_estado = 'CREAR_CONFIRMAR';\n  }\n}\nelse if (estado === 'CREAR_CONFIRMAR') {\n  if (text === 'n' || text === 'no' || text === '9') { mensaje = `❌ Solicitud cancelada.${VOLVER}`; nuevo_datos_temp = {}; log_resultado = 'cancelado'; }\n  else if (text === 's' || text === 'si' || text === 'sí') {\n    const ticketId = generarTicketId();\n    const fechaCreacion = new Date().toISOString().slice(0,19).replace('T',' ');\n    ticket_data = { id_ticket: ticketId, tipo: datosTmp.tipo, prioridad: datosTmp.prioridad, descripcion: datosTmp.descripcion, estado: 'Abierto', creado_por: username, fecha_creacion: fechaCreacion };\n    mensaje = `✅ *¡Solicitud creada exitosamente!*\\n\\n🎫 *Ticket:* \\`${ticketId}\\`\\n🖥️ *Tipo:* ${datosTmp.tipo}\\n⚡ *Prioridad:* ${datosTmp.prioridad}\\n🟡 *Estado:* Abierto\\n\\n📌 _Guarda tu número de ticket para hacer seguimiento._${VOLVER}`;\n    nuevo_datos_temp = {}; accion = 'crear_ticket'; log_resultado = 'ticket_creado_' + ticketId;\n  }  else { mensaje = `⚠️ *Respuesta no reconocida*\\n\\n✅ Escribe *S* para confirmar\\n❌ Escribe *N* para cancelar`; nuevo_estado = 'CREAR_CONFIRMAR'; nuevo_datos_temp = datosTmp; log_resultado = 'opcion_invalida'; }\n}\nelse if (estado === 'CONSULTAR_ID') {\n  if (text === '9') { mensaje = `❌ Cancelado.${VOLVER}`; log_resultado = 'cancelado'; }\n  else {\n    consulta_id = $('Edit Fields').first().json.text.trim().toUpperCase();\n    accion = 'consultar_ticket';\n    log_resultado = 'buscar_' + consulta_id;\n  }\n}\nelse { mensaje = `⚙️ Reiniciando...${VOLVER}`; nuevo_datos_temp = {}; log_resultado = 'reset'; }\n\nreturn [{\n  json: { chatId, username, firstName: nombreUsuario, mensaje, nuevo_estado, nuevo_datos_temp: JSON.stringify(nuevo_datos_temp), accion, ticket_data, consulta_id, sesionExiste, timestamp, log_pantalla: estado, log_opcion: text, log_resultado }\n}];"
      },
